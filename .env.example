# Quotr Environment Variables

# Session secret - REQUIRED: generate a random string
SESSION_SECRET=change-this-to-a-random-secret-string

# API domain for Expo client
EXPO_PUBLIC_DOMAIN=localhost:5000

# Database - leave empty to use SQLite (recommended for local dev)
# DATABASE_URL=postgresql://user:password@localhost:5432/quotr

# Force SQLite even if DATABASE_URL is set
USE_SQLITE=true

# Stripe (optional - for payment features)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...

# Email (Resend API Key)
RESEND_API_KEY=re_123456789

# Email Branding
# EMAIL_FROM="Your Company <notifications@yourdomain.com>"
# EMAIL_BRAND_NAME="Your Company Name"
# EMAIL_BRAND_COLOR="#E11D48"
