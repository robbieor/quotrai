{
  "name": "quotr-enterprise",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --root client",
    "build:dev": "cd client && npm run build",
    "client:dev": "cd client && npm run dev",
    "client:build": "cd client && npm run build",
    "server:dev": "cross-env NODE_ENV=development tsx --tsconfig tsconfig.json server/index.ts",
    "server:build": "esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=server_dist",
    "server:prod": "cross-env NODE_ENV=production node server_dist/index.js",
    "db:push": "drizzle-kit push",
    "build": "npm run client:build && npm run server:build",
    "start": "npm run server:prod",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{js,ts,tsx,css,json}\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@google/genai": "^1.34.0",
    "@replit/object-storage": "^1.0.0",
    "@supabase/supabase-js": "^2.90.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/express-session": "^1.18.2",
    "@types/multer": "^2.0.0",
    "@vitejs/plugin-react": "^5.1.1",
    "axios": "^1.13.2",
    "base64-arraybuffer": "^1.0.2",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.5.0",
    "compression": "^1.8.1",
    "connect-pg-simple": "^10.0.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.39.3",
    "drizzle-zod": "^0.7.1",
    "express": "^4.21.2",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.18.2",
    "framer-motion": "^12.26.2",
    "helmet": "^8.1.0",
    "multer": "^2.0.2",
    "p-limit": "^7.2.0",
    "p-retry": "^7.1.1",
    "pg": "^8.16.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.12.0",
    "resend": "^6.6.0",
    "stripe": "^20.0.0",
    "tsx": "^4.20.6",
    "vite": "^7.2.4",
    "ws": "^8.18.0",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@types/ws": "^8.5.13",
    "drizzle-kit": "^0.30.2",
    "esbuild": "^0.24.2",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3"
  }
}
