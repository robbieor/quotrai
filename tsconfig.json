{
  "compilerOptions": {
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "node",
    "paths": {
      "@/*": [
        "./client/*"
      ],
      "@shared/*": [
        "./shared/*"
      ]
    },
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "types": [
      "node"
    ]
  },
  "exclude": [
    "node_modules",
    "build",
    "dist",
    "client",
    "scripts",
    "server",
    "src"
  ],
  "include": [
    "**/*.ts"
  ]
}