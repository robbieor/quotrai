{
  "compilerOptions": {
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "node",
    "paths": {
      "@/*": [
        "./client/*"
      ],
      "@shared/*": [
        "./shared/*"
      ]
    },
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "target": "ES2022",
    "types": [
      "node"
    ]
  },
  "exclude": [
    "node_modules",
    "build",
    "dist",
    "client",
    "scripts",
    "**/*.test.ts"
  ],
  "include": [
    "shared/**/*.ts"
  ]
}